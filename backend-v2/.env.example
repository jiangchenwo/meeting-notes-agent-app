# Optional: select a different JSON configuration file.
NOTES_RUNTIME_CONFIG_FILE=config/runtime.json

# Environment and .env values override JSON values.
NOTES_RUNTIME_PROVIDER=lm_studio_openai
NOTES_RUNTIME_INFERENCE_BASE_URL=http://localhost:1234/v1
NOTES_RUNTIME_CONTROL_BASE_URL=http://localhost:1234
NOTES_RUNTIME_MODEL_KEY=google/gemma-4-26b-a4b-qat
# NOTES_RUNTIME_MODEL_INSTANCE_ID=loaded-instance-id
NOTES_RUNTIME_MODEL_ARCHITECTURE=gemma4
NOTES_RUNTIME_MODEL_FORMAT=mlx
NOTES_RUNTIME_MODEL_QUANTIZATION_NAME=4bit
NOTES_RUNTIME_MODEL_BITS_PER_WEIGHT=4
NOTES_RUNTIME_MODEL_LOADED_CONTEXT=40960
NOTES_RUNTIME_CONTROL_TIMEOUT_SECONDS=10
NOTES_RUNTIME_INFERENCE_TIMEOUT_SECONDS=240

# Keep tokens out of JSON. Do not commit a populated .env file.
# NOTES_RUNTIME_API_TOKEN=local-secret

# Optional development-only evaluation judge. It is disabled by default and
# also requires the CLI's explicit remote-judge opt-in.
NOTES_EVAL_JUDGE_CONFIG_FILE=config/evaluation/judge.json
# NOTES_EVAL_JUDGE_ENV_FILE=.env
# NOTES_EVAL_JUDGE_PROVIDER=openai_compatible
# NOTES_EVAL_JUDGE_MODEL=inexpensive-model-id
# NOTES_EVAL_JUDGE_BASE_URL=https://provider.example/v1
# NOTES_EVAL_JUDGE_TIMEOUT_SECONDS=30
# NOTES_EVAL_JUDGE_MIN_INTERVAL_SECONDS=4.1
# NOTES_EVAL_JUDGE_MAX_COST_USD=1.00
# NOTES_EVAL_JUDGE_INPUT_COST_PER_MILLION=0.25
# NOTES_EVAL_JUDGE_OUTPUT_COST_PER_MILLION=1.50
# NOTES_EVAL_JUDGE_API_TOKEN=environment-only-secret
